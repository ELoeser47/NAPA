<script>
  function goTo(panel){
    document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
    document.querySelector('.nav-btn[data-panel="'+panel+'"]').classList.add('active');
    document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
    document.getElementById('panel-'+panel).classList.add('active');
    window.scrollTo({top:0,behavior:'smooth'});
  }
  document.querySelectorAll('.nav-btn').forEach(b=>{
    b.addEventListener('click',()=>goTo(b.dataset.panel));
  });

  const explorerEl = document.getElementById('explorer');
  document.querySelectorAll('.lease-opt').forEach(opt=>{
    opt.addEventListener('click',()=>{
      document.querySelectorAll('.lease-opt').forEach(o=>o.classList.remove('active'));
      opt.classList.add('active');
      explorerEl.dataset.lease = opt.dataset.lease;
    });
  });

  document.querySelectorAll('.region-opt').forEach(opt=>{
    opt.addEventListener('click',()=>{
      document.querySelectorAll('.region-opt').forEach(o=>o.classList.remove('active'));
      document.querySelectorAll('.region-panel').forEach(p=>p.classList.remove('active'));
      opt.classList.add('active');
      document.querySelector('.region-panel[data-region="'+opt.dataset.region+'"]').classList.add('active');
    });
  });

  document.querySelectorAll('.etab').forEach(t=>{
    t.addEventListener('click',()=>{
      document.querySelectorAll('.etab').forEach(x=>x.classList.remove('active'));
      document.querySelectorAll('.epanel').forEach(x=>x.classList.remove('active'));
      t.classList.add('active');
      document.getElementById('p-'+t.dataset.p).classList.add('active');
    });
  });

  // FAQ slider
  (function(){
    const slidesEl = document.getElementById('faqSlides');
    const dots = document.querySelectorAll('.faq-dot');
    const total = dots.length;
    let idx = 0;
    function render(){
      slidesEl.style.transform = 'translateX(-' + (idx*100) + '%)';
      dots.forEach((d,i)=>d.classList.toggle('active', i===idx));
    }
    document.getElementById('faqPrev').addEventListener('click',()=>{
      idx = (idx - 1 + total) % total;
      render();
    });
    document.getElementById('faqNext').addEventListener('click',()=>{
      idx = (idx + 1) % total;
      render();
    });
    dots.forEach(d=>{
      d.addEventListener('click',()=>{
        idx = parseInt(d.dataset.i);
        render();
      });
    });
  })();

  // Term tooltip popovers
  const popover = document.getElementById('popover');
  const popoverText = document.getElementById('popover-text');
  document.querySelectorAll('.term').forEach(term=>{
    term.addEventListener('click',(e)=>{
      e.stopPropagation();
      const def = term.dataset.def;
      popoverText.textContent = def;
      const rect = term.getBoundingClientRect();
      popover.style.display = 'block';
      let left = rect.left;
      const maxLeft = window.innerWidth - 300;
      if(left > maxLeft) left = maxLeft;
      popover.style.left = Math.max(12,left) + 'px';
      popover.style.top = (rect.bottom + 10) + 'px';
    });
  });
  document.addEventListener('click',()=>{ popover.style.display='none'; });
  popover.addEventListener('click',(e)=>e.stopPropagation());
</script>

