<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NAPA / O'Reilly — Landlord Impact</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --navy-950:#001233;
    --navy-800:#002D7A;
    --navy-700:#003D9E;
    --paper:#EFF3FA;
    --card:#FFFFFF;
    --ink:#0A1E4D;
    --ink-soft:#4E5F80;
    --line:#D3DDEF;
    --amber:#E8A500;
    --amber-soft:#FFF3D6;
    --risk:#A93A3F;
    --risk-soft:#F7E4E3;
    --safe:#2E6E52;
    --safe-soft:#DFEEE6;
  }
  *{box-sizing:border-box;}
  html,body{height:100%;}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:'Inter',sans-serif;line-height:1.5;display:flex;flex-direction:column;min-height:100vh;}
  h1,h2,h3{font-family:'Fraunces',serif;color:var(--navy-950);margin:0;}
  .mono{font-family:'IBM Plex Mono',monospace;}
  .wrap{max-width:1000px;margin:0 auto;padding:0 24px;width:100%;}

  /* ---- HEADER (fixed readability pass) ---- */
  header{
    background:var(--navy-950);
    border-bottom:3px solid var(--amber);
    position:sticky;top:0;z-index:20;
  }
  .head-top{padding:20px 0 16px;text-align:center;}
  .head-top .eyebrow{
    font-family:'IBM Plex Mono',monospace;
    font-size:11.5px;letter-spacing:0.1em;text-transform:uppercase;
    color:#AFC4E0;
    margin-bottom:8px;
  }
  .head-top h1{
    color:#FFFFFF;
    font-size:clamp(1.7rem,4.2vw,2.5rem);
    font-weight:700;
    line-height:1.18;
    max-width:820px;
    margin:0 auto;
    letter-spacing:-0.008em;
  }
  .head-top p{
    color:#D7E2F1;
    font-size:0.95rem;
    max-width:620px;
    margin:10px auto 0;
  }
  .ticker-wrap{
    overflow:hidden;margin-top:18px;border-top:1px solid rgba(255,255,255,.14);
    border-bottom:1px solid rgba(255,255,255,.14);padding:10px 0;
  }
  .ticker-track{display:flex;width:max-content;animation:ticker-scroll 32s linear infinite;}
  .ticker-item{
    display:flex;align-items:baseline;gap:8px;padding:0 28px;white-space:nowrap;
    font-family:'IBM Plex Mono',monospace;font-size:12.5px;color:#D7E2F1;
  }
  .ticker-item .t-num{font-weight:700;color:#fff;font-size:13.5px;}
  .ticker-item .t-dot{color:var(--amber);margin-left:20px;}
  @keyframes ticker-scroll{
    from{transform:translateX(0);}
    to{transform:translateX(-50%);}
  }
  .next-earnings-badge{
    display:flex;align-items:center;justify-content:center;gap:8px;
    margin-top:14px;font-family:'IBM Plex Mono',monospace;font-size:12px;
    color:#D7E2F1;
  }
  .next-earnings-badge strong{color:var(--amber);font-weight:700;}
  nav{background:var(--amber);border-top:1px solid rgba(0,0,0,.1);}
  .nav-inner{display:flex;gap:4px;overflow-x:auto;padding:6px 0;justify-content:center;}
  .nav-btn{
    flex:0 0 auto;
    font-family:'IBM Plex Mono',monospace;
    font-size:12.5px;font-weight:600;
    color:#5C4400;background:transparent;border:none;
    padding:12px 18px;cursor:pointer;
    border-bottom:3px solid transparent;
    white-space:nowrap;
    transition:all .15s ease;
  }
  .nav-btn:hover{color:#1A1200;}
  .nav-btn.active{color:#1A1200;border-bottom-color:var(--navy-950);}

  main{flex:1;padding:32px 0 20px;}
  .panel{display:none;animation:fadein .3s ease;}
  .panel.active{display:block;}
  @keyframes fadein{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

  .kicker{font-family:'IBM Plex Mono',monospace;font-size:11.5px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.1em;margin-bottom:6px;text-align:center;}
  .section-title{font-size:1.35rem;font-weight:600;margin-bottom:20px;text-align:center;}

  /* Overview */
  .stat-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:24px;}
  @media(max-width:640px){.stat-cards{grid-template-columns:1fr 1fr;}}
  .stat-card{background:var(--card);border:1px solid var(--line);border-radius:10px;padding:18px 20px;}
  .stat-card .num{font-family:'Fraunces',serif;font-size:1.6rem;font-weight:600;color:var(--navy-950);}
  .stat-card .lab{font-family:'IBM Plex Mono',monospace;font-size:10.5px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.05em;margin-top:2px;}
  .jump-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
  @media(max-width:640px){.jump-grid{grid-template-columns:1fr;}}
  .jump-card{
    background:var(--card);border:1px solid var(--line);border-radius:10px;padding:20px;cursor:pointer;
    transition:border-color .15s ease, transform .15s ease;
  }
  .jump-card:hover{border-color:var(--navy-700);transform:translateY(-2px);}
  .jump-card h3{font-size:1rem;margin-bottom:6px;}
  .jump-card p{font-size:0.85rem;color:var(--ink-soft);margin:0;}
  .jump-card .arrow{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--navy-700);margin-top:10px;display:inline-block;}

  /* Outcomes (possibilities) */
  .poss-grid{display:grid;grid-template-columns:1fr;gap:12px;}
  @media(min-width:760px){.poss-grid{grid-template-columns:repeat(3,1fr);}}
  .poss-card{background:var(--card);border:1px solid var(--line);border-radius:12px;padding:20px;text-align:center;}
  .poss-head{margin-bottom:14px;}
  .poss-head h3{font-size:1.15rem;font-weight:700;line-height:1.3;color:var(--navy-950);}
  .bubble-col{display:flex;flex-direction:column;gap:8px;}
  .out-bubble{
    display:flex;align-items:center;justify-content:center;gap:8px;
    padding:9px 12px;border-radius:10px;font-size:0.82rem;line-height:1.4;
  }
  .out-bubble .obdot{width:7px;height:7px;border-radius:50%;flex:0 0 7px;}
  .out-bubble.risk{background:var(--risk-soft);color:var(--risk);}
  .out-bubble.risk .obdot{background:var(--risk);}
  .out-bubble.watch{background:var(--amber-soft);color:var(--amber);}
  .out-bubble.watch .obdot{background:var(--amber);}
  .out-bubble.up{background:var(--safe-soft);color:var(--safe);}
  .out-bubble.up .obdot{background:var(--safe);}

  /* Impact explorer (scenarios) */
  .lease-select{
    background:var(--card);border:1px solid var(--line);border-radius:14px;
    padding:20px 22px 22px;margin-bottom:20px;box-shadow:0 2px 10px rgba(10,27,51,.05);
  }
  .lease-select-label{
    font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-soft);
    text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;text-align:center;
  }
  .lease-options{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  @media(max-width:600px){.lease-options{grid-template-columns:1fr;}}
  .lease-opt{
    border:2px solid var(--line);border-radius:12px;padding:16px 18px;cursor:pointer;
    text-align:center;background:var(--paper);transition:all .18s ease;
  }
  .lease-opt:hover{border-color:var(--navy-700);}
  .lease-opt.active{border-color:var(--navy-950);background:var(--navy-950);box-shadow:0 6px 16px rgba(10,27,51,.22);}
  .lo-title{font-weight:700;font-size:0.95rem;color:var(--navy-950);margin-bottom:4px;}
  .lease-opt.active .lo-title{color:#fff;}
  .lo-desc{font-size:0.8rem;color:var(--ink-soft);}
  .lease-opt.active .lo-desc{color:#AFC4E0;}

  .scenario-select{
    background:var(--card);border:1px solid var(--line);border-radius:14px;
    padding:20px 22px 22px;margin-bottom:16px;box-shadow:0 2px 10px rgba(10,27,51,.05);
  }
  .explorer{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:8px;}
  .etabs-label{
    font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--ink-soft);
    text-transform:uppercase;letter-spacing:.08em;text-align:center;margin-bottom:14px;
  }
  .etabs{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
  @media(max-width:600px){.etabs{grid-template-columns:1fr;}}
  .etab{
    border:2px solid var(--line);border-radius:12px;padding:16px 14px;cursor:pointer;
    text-align:center;background:var(--paper);transition:all .18s ease;
  }
  .etab:hover{border-color:var(--navy-700);}
  .etab.active{border-color:var(--navy-950);background:var(--navy-950);box-shadow:0 6px 16px rgba(10,27,51,.22);}
  .etab .et-title{font-weight:700;font-size:0.92rem;color:var(--navy-950);margin-bottom:4px;font-family:'Inter',sans-serif;}
  .etab.active .et-title{color:#fff;}
  .etab .et-desc{font-size:0.78rem;color:var(--ink-soft);}
  .etab.active .et-desc{color:#AFC4E0;}
  .epanel{display:none;padding:20px 24px 26px;text-align:center;}
  .epanel.active{display:block;animation:fadein .3s ease;}
  .epanel h3{font-size:1.15rem;font-weight:700;color:var(--navy-950);margin-bottom:18px;}
  .explorer[data-lease="corp"] .detail-block.for-franchise{display:none;}
  .explorer[data-lease="franchise"] .detail-block.for-corp{display:none;}
  .explorer[data-lease="corp"] .detail-block.for-corp{display:flex;}
  .explorer[data-lease="franchise"] .detail-block.for-franchise{display:flex;}
  .detail-block{display:none;flex-direction:row;flex-wrap:wrap;gap:14px;max-width:100%;margin:0 auto;justify-content:center;}
  .impact-group{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1;min-width:150px;max-width:200px;}
  .impact-caption{
    font-family:'IBM Plex Mono',monospace;font-size:10.5px;font-weight:600;
    text-transform:uppercase;letter-spacing:.08em;
  }
  .impact-caption.risk{color:var(--risk);}
  .impact-caption.watch{color:var(--amber);}
  .impact-caption.up{color:var(--safe);}
  .impact-pill{
    padding:12px 20px;border-radius:10px;font-size:0.9rem;line-height:1.4;
    text-align:center;max-width:100%;
  }
  .impact-pill.risk{background:var(--risk-soft);color:var(--risk);}
  .impact-pill.watch{background:var(--amber-soft);color:var(--amber);}
  .impact-pill.up{background:var(--safe-soft);color:var(--safe);}
  .impact-pill p{margin:0;color:inherit;font-size:inherit;}

  /* Overlap */
  .jump-link{
    margin:22px auto 0;max-width:400px;text-align:center;cursor:pointer;
    font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;
    color:var(--navy-700);border:1px solid var(--line);border-radius:999px;
    padding:11px 18px;transition:all .15s ease;
  }
  .jump-link:hover{border-color:var(--navy-700);background:var(--paper);color:var(--navy-950);}
  .stat-callout{
    display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;
    background:var(--risk-soft);border:1px solid var(--risk);border-radius:12px;
    padding:20px 24px;margin-top:16px;text-align:center;
  }
  .stat-callout .sc-num{font-family:'Fraunces',serif;font-weight:700;font-size:2.2rem;color:var(--risk);flex:0 0 auto;}
  .stat-callout .sc-text{font-size:0.92rem;color:var(--ink);line-height:1.5;flex:1;min-width:220px;}
  .stat-mini{display:flex;flex-direction:column;gap:10px;}
  .stat-row{display:flex;justify-content:space-between;gap:14px;align-items:center;padding:12px 16px;background:var(--card);border:1px solid var(--line);border-radius:8px;}
  .stat-row.flag{border-color:var(--risk);background:var(--risk-soft);}
  .stat-row .val{font-family:'Fraunces',serif;font-size:1.15rem;font-weight:600;color:var(--navy-950);flex:0 0 auto;}
  .stat-row.flag .val{color:var(--risk);}
  .stat-row .lab{font-size:0.83rem;color:var(--ink-soft);}

  /* Checklist */
  .checklist{background:var(--navy-950);border-radius:14px;padding:26px 24px;color:#EAF0F8;}
  .checklist h2{color:#fff;font-size:1.15rem;margin-bottom:6px;}
  .checklist .sub{color:#9FB4D3;font-size:0.86rem;margin:0 0 18px;}
  .itabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px;}
  .itab{font-family:'IBM Plex Mono',monospace;font-size:11px;padding:8px 13px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);color:#B9CEEA;cursor:pointer;transition:all .15s ease;}
  .itab:hover{border-color:#B9CEEA;color:#fff;}
  .itab.active{background:var(--amber);border-color:var(--amber);color:#1A1200;}
  .ipanel{display:none;}
  .ipanel.active{display:block;animation:fadein .3s ease;}
  .check-item{display:flex;gap:12px;align-items:flex-start;padding:10px 0;border-top:1px solid rgba(255,255,255,.1);cursor:pointer;}
  .check-item:last-child{border-bottom:1px solid rgba(255,255,255,.1);}
  .check-box{width:18px;height:18px;flex:0 0 18px;border:1.5px solid #6E88AC;border-radius:4px;margin-top:2px;display:flex;align-items:center;justify-content:center;}
  .check-box svg{opacity:0;width:10px;height:10px;}
  .check-item.checked .check-box{background:var(--amber);border-color:var(--amber);}
  .check-item.checked .check-box svg{opacity:1;}
  .check-item.checked .check-text{color:#7F93AC;text-decoration:line-through;}
  .check-text{font-size:0.89rem;color:#DCE6F2;}
  .progress-track{height:5px;background:rgba(255,255,255,.12);border-radius:99px;overflow:hidden;margin-top:18px;}
  .progress-fill{height:100%;background:var(--amber);width:0%;transition:width .3s ease;}
  .progress-label{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#9FB4D3;margin-top:6px;}

  /* Overlap regional highlight cards */
  .overlap-bubbles{display:flex;gap:12px;flex-wrap:wrap;}
  .ov-bubble{
    display:flex;flex-direction:column;align-items:center;gap:4px;
    background:var(--card);border:1px solid var(--line);border-radius:12px;
    padding:14px 18px;flex:1;min-width:150px;text-align:center;
  }
  .ov-bubble .ov-num{font-family:'Fraunces',serif;font-weight:700;font-size:1.3rem;color:var(--navy-950);}
  .ov-bubble .ov-lab{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--ink-soft);text-transform:uppercase;letter-spacing:.04em;line-height:1.3;}
  .region-select{
    background:var(--card);border:1px solid var(--line);border-radius:14px;
    padding:20px 22px 22px;margin-top:6px;box-shadow:0 2px 10px rgba(10,27,51,.05);
  }
  .region-options{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
  .region-options.five-col{grid-template-columns:repeat(5,1fr);}
  @media(max-width:700px){.region-options.five-col{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:600px){.region-options{grid-template-columns:1fr;}}
  .region-opt{
    border:2px solid var(--line);border-radius:12px;padding:16px 18px;cursor:pointer;
    text-align:center;background:var(--paper);transition:all .18s ease;
  }
  .region-opt:hover{border-color:var(--navy-700);}
  .region-opt.active{border-color:var(--navy-950);background:var(--navy-950);box-shadow:0 6px 16px rgba(10,27,51,.22);}
  .region-opt .ro-title{font-weight:700;font-size:0.95rem;color:var(--navy-950);margin-bottom:4px;}
  .region-opt.active .ro-title{color:#fff;}
  .region-opt .ro-desc{font-size:0.8rem;color:var(--ink-soft);}
  .region-opt.active .ro-desc{color:#AFC4E0;}
  .region-panel{display:none;margin-top:20px;}
  .region-panel.active{display:block;animation:fadein .3s ease;}
  .metro-note{
    font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--ink-soft);
    text-transform:uppercase;letter-spacing:.05em;text-align:center;margin:22px 0 10px;
  }
  .metro-chips{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;}
  .metro-chip{
    font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;
    background:var(--paper);border:1px solid var(--line);border-radius:999px;
    padding:7px 14px;color:var(--ink-soft);
  }

  .watch-grid{display:grid;gap:16px;margin-top:6px;}
  .watch-card{
    background:var(--card);border:1px solid var(--line);border-radius:10px;
    padding:20px;border-top:4px solid var(--navy-700);
  }
  .watch-card.risk-high{border-top-color:var(--risk);}
  .watch-card.risk-mid{border-top-color:var(--amber);}
  .watch-card .level{font-family:'IBM Plex Mono',monospace;font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;color:var(--ink-soft);margin-bottom:8px;}
  .watch-card h3{font-size:1.05rem;margin-bottom:8px;}
  .watch-card p{color:var(--ink-soft);font-size:0.88rem;margin:0;line-height:1.5;}

  footer{padding:18px 0 26px;color:var(--ink-soft);font-size:0.76rem;border-top:1px solid var(--line);}

  /* Profile / Further Questions */
  .profile-card{
    max-width:460px;margin:0 auto;background:var(--card);border:1px solid var(--line);
    border-radius:16px;padding:36px 32px 32px;text-align:center;
    box-shadow:0 4px 18px rgba(10,27,51,.06);
  }
  .profile-photo-wrap{
    width:132px;height:132px;border-radius:50%;overflow:hidden;margin:0 auto 18px;
    border:4px solid var(--amber);box-shadow:0 6px 16px rgba(10,27,51,.15);
  }
  .profile-photo{width:100%;height:100%;object-fit:cover;display:block;}
  .profile-name{font-size:1.3rem;margin-bottom:2px;}
  .profile-title{
    font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--ink-soft);
    text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;
  }
  .profile-specialty{
    display:inline-block;background:var(--amber-soft);color:#8A6400;
    font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:600;
    text-transform:uppercase;letter-spacing:.04em;padding:6px 14px;border-radius:999px;
    margin-bottom:18px;
  }
  .profile-bio{font-size:0.92rem;color:var(--ink-soft);line-height:1.6;margin:0 0 24px;}
  .profile-contact{display:flex;flex-direction:column;gap:10px;}
  .contact-btn{
    display:flex;align-items:center;justify-content:center;gap:9px;
    font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600;
    color:var(--navy-950);background:var(--paper);border:1px solid var(--line);
    border-radius:10px;padding:12px 16px;text-decoration:none;transition:all .15s ease;
  }
  .contact-btn:hover{border-color:var(--navy-700);background:#fff;}
  .contact-btn svg{flex:0 0 auto;color:var(--navy-700);}

  /* ---- Friendlier / educational additions ---- */
  .intro-card{
    background:linear-gradient(135deg, var(--navy-950) 0%, var(--navy-800) 100%);
    border-radius:14px;padding:24px 24px 26px;color:#EAF0F8;margin-bottom:24px;
  }
  .intro-card h2{color:#fff;font-size:1.15rem;margin-bottom:18px;}
  .faq-slider{position:relative;}
  .faq-track{overflow:hidden;}
  .faq-slides{display:flex;transition:transform .35s ease;}
  .faq-slide{flex:0 0 100%;padding:2px;}
  .faq-card{padding:6px 4px;min-height:110px;}
  .faq-card .qtext{display:block;font-family:'Fraunces',serif;font-weight:700;color:#fff;font-size:1.25rem;margin:0 0 10px;line-height:1.25;}
  .faq-card .atext{color:#C7D6E9;font-size:0.92rem;line-height:1.55;margin:0;}
  .faq-cta{
    display:inline-block;margin-top:14px;cursor:pointer;
    font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600;
    color:#1A1200;background:var(--amber);border-radius:999px;
    padding:9px 16px;transition:all .15s ease;
  }
  .faq-cta:hover{opacity:0.88;}
  .faq-nav{display:flex;align-items:center;justify-content:center;gap:16px;margin-top:16px;}
  .faq-arrow{
    width:34px;height:34px;border-radius:50%;border:1px solid rgba(255,255,255,.25);
    background:rgba(255,255,255,.06);color:#fff;cursor:pointer;
    display:flex;align-items:center;justify-content:center;transition:all .15s ease;flex:0 0 auto;
  }
  .faq-arrow:hover{background:rgba(255,255,255,.16);}
  .faq-dots{display:flex;gap:7px;}
  .faq-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer;transition:all .15s ease;}
  .faq-dot.active{background:var(--amber);width:18px;border-radius:4px;}

  .steps{display:flex;gap:10px;flex-wrap:wrap;margin:22px 0 4px;}
  .step-chip{
    display:flex;align-items:center;gap:8px;
    background:var(--card);border:1px solid var(--line);border-radius:999px;
    padding:8px 16px 8px 10px;cursor:pointer;font-size:0.83rem;color:var(--ink-soft);
    transition:all .15s ease;
  }
  .step-chip:hover{border-color:var(--navy-700);color:var(--navy-950);}
